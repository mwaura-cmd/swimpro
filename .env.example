# Example environment file - copy to .env and fill in values (DO NOT commit .env)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional service role key for scripts
SUPABASE_SERVICE_ROLE_KEY=
# Admin password for local testing (do NOT commit real password)
ADMIN_PASSWORD=your_strong_password_here

# Paystack keys (set in deployment or local .env only)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

REDIS_URL=
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
PORT=4000
